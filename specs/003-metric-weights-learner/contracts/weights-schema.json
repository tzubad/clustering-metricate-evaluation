{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metricate.dev/schemas/weights-v1.json",
  "title": "MetricWeights",
  "description": "Learned coefficients for computing compound clustering quality score",
  "type": "object",
  "required": ["version", "coefficients", "bias"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (semver major.minor)",
      "examples": ["1.0"]
    },
    "coefficients": {
      "type": "object",
      "description": "Mapping of normalized metric names to their weights",
      "additionalProperties": {
        "type": "number"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_\\-\\s()]+_norm$"
      },
      "minProperties": 1,
      "examples": [{
        "Silhouette_norm": 0.1523,
        "Davies-Bouldin_norm": 0.0892,
        "Calinski-Harabasz_norm": 0.0
      }]
    },
    "bias": {
      "type": "number",
      "description": "Intercept term from regression model"
    },
    "metadata": {
      "type": "object",
      "description": "Optional training metadata",
      "properties": {
        "regularization": {
          "type": "string",
          "enum": ["ridge", "lasso"],
          "description": "Regularization type used"
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "description": "Regularization strength"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of training"
        },
        "training_samples": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of samples used for training"
        },
        "cv_r2": {
          "type": "number",
          "maximum": 1,
          "description": "Cross-validation R² score"
        },
        "non_zero_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of non-zero coefficients"
        }
      }
    }
  },
  "examples": [{
    "version": "1.0",
    "coefficients": {
      "Silhouette_norm": 0.1523,
      "Davies-Bouldin_norm": 0.0892,
      "Calinski-Harabasz_norm": 0.1245,
      "Dunn Index_norm": 0.0,
      "R-squared_norm": 0.0678
    },
    "bias": 0.2341,
    "metadata": {
      "regularization": "ridge",
      "alpha": 1.0,
      "created_at": "2026-03-01T14:30:00Z",
      "training_samples": 74,
      "cv_r2": 0.82,
      "non_zero_count": 28
    }
  }]
}
